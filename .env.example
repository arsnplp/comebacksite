# Domaine Plausible (ex: getcomeback.fr) — laisser vide pour désactiver l'analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Endpoint de réception des leads (Formspree, API interne…) — laisser vide en local :
# le formulaire simule alors le succès sans rien envoyer (voir components/forms/LeadForm.tsx)
NEXT_PUBLIC_LEAD_ENDPOINT=
